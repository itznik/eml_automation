# Email Configuration
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your_email@gmail.com
IMAP_PASS=your_app_password

# AI Configuration
GEMINI_API_KEY=your_gemini_api_key

